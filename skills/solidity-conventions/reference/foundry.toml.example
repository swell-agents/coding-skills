# Starter foundry.toml — strict defaults that match SKILL.md.

[profile.default]
src = "src"
out = "out"
libs = ["lib"]
optimizer = true
optimizer_runs = 200
solc = "0.8.22"
verbosity = 3
fuzz = { runs = 1024 }
invariant = { runs = 256, depth = 64 }

[fmt]
sort_imports = true
contract_new_lines = true
bracket_spacing = true
line_length = 120
tab_width = 4
quote_style = "double"

[rpc_endpoints]
# Add per-network RPC endpoints here.
