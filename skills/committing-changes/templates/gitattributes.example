# Mark generated/vendored files so GitHub collapses them in PR diffs and
# size labelers can skip them. Append to your repo's .gitattributes.

package-lock.json   linguist-generated=true
yarn.lock           linguist-generated=true
pnpm-lock.yaml      linguist-generated=true
go.sum              linguist-generated=true
uv.lock             linguist-generated=true
poetry.lock         linguist-generated=true
Cargo.lock          linguist-generated=true
Gemfile.lock        linguist-generated=true

**/*.pb.go          linguist-generated=true
**/*_pb2.py         linguist-generated=true
**/*_pb2_grpc.py    linguist-generated=true

vendor/**           linguist-vendored=true
